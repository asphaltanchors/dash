# Database credentials for PostgreSQL
# These are used to construct DATABASE_URL for all services

DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# The DATABASE_URL is automatically constructed in docker-compose.yml as:
# postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/yourdb
#
# For development: Use simple credentials like above
# For production: Use strong passwords and consider secrets management
